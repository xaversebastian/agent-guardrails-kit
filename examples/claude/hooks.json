{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/agent-guardrails-bash.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/agent-guardrails-secret.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/agent-guardrails-secret.sh" },
          { "type": "command", "command": "PII_ALLOW_EMAIL_DOMAINS=example.com $CLAUDE_PROJECT_DIR/.claude/hooks/agent-guardrails-pii.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/agent-guardrails-protected.sh" }
        ]
      }
    ]
  }
}
